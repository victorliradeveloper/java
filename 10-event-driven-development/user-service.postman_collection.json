{
  "info": {
    "name": "User Service — Event-Driven",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Requisições para testar o fluxo de eventos do user-service. Cada chamada publica um evento no RabbitMQ e dispara um email no Mailtrap.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Registrar usuário",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token salvo automaticamente');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Victor Lira\",\n  \"email\": \"victor@teste.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Cadastra um novo usuário.\n\nEvento publicado: `user.registered` → fila `email.registered.queue`\nEmail enviado: Boas-vindas"
          }
        },
        {
          "name": "2. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token salvo automaticamente');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"victor@teste.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Autentica o usuário e retorna o JWT.\n\nEvento publicado: `user.login` → fila `email.login.queue`\nEmail enviado: Notificação de novo acesso\n\nO token é salvo automaticamente na variável `token`."
          }
        },
        {
          "name": "3. Login com credenciais inválidas",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"victor@teste.com\",\n  \"password\": \"senha-errada\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Deve retornar 401 com ErrorResponseDTO."
          }
        },
        {
          "name": "4. Registrar usuário duplicado",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Victor Lira\",\n  \"email\": \"victor@teste.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Deve retornar 409 — email já cadastrado."
          }
        },
        {
          "name": "5. Registrar com dados inválidos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"email-invalido\",\n  \"password\": \"123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Deve retornar 400 com fieldErrors detalhando cada campo inválido."
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "6. Criar pedido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Notebook Dell XPS 15\",\n  \"amount\": 8500.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders"]
            },
            "description": "Cria um pedido para o usuário autenticado.\n\nEvento publicado: `order.created` → fila `email.order.queue`\nEmail enviado: Confirmação de pedido\n\nRequer o token JWT salvo pelo login."
          }
        },
        {
          "name": "7. Criar pedido sem autenticação",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Teclado Mecânico\",\n  \"amount\": 350.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders"]
            },
            "description": "Deve retornar 403 — rota protegida, sem JWT."
          }
        },
        {
          "name": "8. Criar pedido com valor inválido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"\",\n  \"amount\": -100\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders"]
            },
            "description": "Deve retornar 400 com fieldErrors."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "9. Solicitar reset de senha",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/password-reset",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "password-reset"]
            },
            "description": "Solicita o email de redefinição de senha para o usuário autenticado.\n\nEvento publicado: `user.password` → fila `email.password.queue`\nEmail enviado: Link de redefinição de senha"
          }
        },
        {
          "name": "10. Reset de senha sem autenticação",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/users/password-reset",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "password-reset"]
            },
            "description": "Deve retornar 403 — rota protegida, sem JWT."
          }
        }
      ]
    }
  ]
}
